    {
      "cell_type": "code",
      "source": [
        "# Crear la figura para visualizar la conservación\n",
        "fig, axes = plt.subplots(2, 1, figsize=(12, 8), sharex=True)\n",
        "\n",
        "# Gráfica de error de energía\n",
        "dias_arr = ts * UT_days\n",
        "axes[0].plot(dias_arr, err_E, color='blue', label='Error Relativo E')\n",
        "axes[0].axhline(y=1e-6, color='red', linestyle='--', label='Umbral 10⁻⁶')\n",
        "axes[0].set_yscale('log')\n",
        "axes[0].set_ylabel('Error relativo |ΔE/E₀|')\n",
