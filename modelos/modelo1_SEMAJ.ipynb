          "text": [
            "Condiciones iniciales (2028-01-01) — unidades canónicas:\n",
            "Cuerpo            m_can      x [AU]     y [AU]     z [AU]   v [AU/UT]\n",
            "--------------------------------------------------------------------\n",
            "Sol          1.0000e+00      0.0008    -0.0033     0.0000      0.0003\n",
            "Tierra       3.0035e-06     -0.1647     0.9660    -0.0000      1.0167\n",
            "Luna         3.6959e-08     -0.1624     0.9645     0.0001      0.9943\n",
            "Jupiter      9.5459e-04     -5.2761     1.2417     0.1129      0.4201\n",
            "Apophis      1.3575e-20      0.1247     0.9447    -0.0476      1.0024\n"
