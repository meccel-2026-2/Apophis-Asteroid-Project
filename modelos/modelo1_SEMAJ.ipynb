        "\n",
        "# Gráfica de error de momento angular\n",
        "axes[1].plot(dias_arr, err_L, color='green', label='Error Relativo L')\n",
        "axes[1].axhline(y=1e-6, color='red', linestyle='--', label='Umbral 10⁻⁶')\n",
        "axes[1].set_yscale('log')\n",
        "axes[1].set_xlabel('Días desde 2028-01-01')\n",
        "axes[1].set_ylabel('Error relativo |ΔL/L₀|')\n",
        "axes[1].set_title('Conservación del Momento Angular Total')\n",
        "axes[1].legend()\n",
        "axes[1].grid(True, which='both', ls='--', alpha=0.5)\n",
